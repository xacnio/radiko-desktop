{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "Radiko Desktop",
    "version": "1.0.6",
    "identifier": "dev.xacnio.radikodesktop",
    "build": {
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "bundle": {
        "active": true,
        "createUpdaterArtifacts": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "displayLanguageSelector": false,
                "installMode": "currentUser"
            }
        }
    },
    "app": {
        "withGlobalTauri": false,
        "windows": [
            {
                "label": "main",
                "title": "Radiko Desktop",
                "width": 1100,
                "height": 700,
                "resizable": true,
                "fullscreen": false,
                "center": true,
                "minWidth": 650,
                "minHeight": 600,
                "decorations": false,
                "transparent": false,
                "visible": false
            }
        ],
        "security": {
            "assetProtocol": {
                "enable": true,
                "scope": [
                    "**",
                    "$APPCACHE/**",
                    "$APPDATA/**",
                    "$RESOURCE/**"
                ]
            }
        }
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/xacnio/radiko-desktop/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDBDNzYyN0FGNThDMzNCOTMKUldTVE84TllyeWQyREFBLzlHV2RNSitOY2VTd2NFZmZFbE5hRk9MaHdvRWUwTUpNVVp1TS9FOFUK"
        }
    }
}